{
  "name": "snowboy",
  "version": "0.1.0-pre-alpha",
  "private": true,
  "description": "Cross-platform open-source desktop IDE for Snowflake.",
  "license": "MIT",
  "type": "module",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "bun test ./tests/unit/ --pass-with-no-tests",
    "test:e2e": "electron-vite build && playwright test -c tests/e2e/playwright.config.ts",
    "format": "prettier --write .",
    "rebuild": "bun run scripts/rebuild-natives.ts",
    "postinstall": "bun run rebuild"
  },
  "trustedDependencies": [
    "electron",
    "better-sqlite3"
  ],
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "autoprefixer": "^10.4.20",
    "electron": "^32.3.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^15.13.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.0",
    "svelte-eslint-parser": "^1.0.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "snowflake-sdk": "^2.4.1"
  }
}
