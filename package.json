{
  "name": "snowboy",
  "version": "0.1.0-pre-alpha",
  "private": true,
  "description": "Cross-platform open-source desktop IDE for Snowflake.",
  "license": "MIT",
  "type": "module",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "dev:clean": "rimraf out && electron-vite dev",
    "build": "electron-vite build",
    "build:linux": "electron-vite build && electron-builder --linux",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && svelte-check --tsconfig tsconfig.renderer.json",
    "test": "bun test ./tests/unit/ --preload ./tests/unit/setup.ts --pass-with-no-tests",
    "test:e2e": "electron-vite build && playwright test -c tests/e2e/playwright.config.ts",
    "format": "prettier --write .",
    "rebuild": "bun run scripts/rebuild-natives.ts",
    "postinstall": "bun run rebuild"
  },
  "build": {
    "appId": "com.snowboy.app",
    "productName": "Snowboy",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "icon": "resources/icon.png"
  },
  "trustedDependencies": [
    "electron",
    "better-sqlite3"
  ],
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.16.0",
    "@lucide/svelte": "^0.482.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "autoprefixer": "^10.4.20",
    "bits-ui": "^1.4.7",
    "clsx": "^2.1.1",
    "cmdk-sv": "^0.0.19",
    "electron": "^32.3.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^15.13.0",
    "lucide-svelte": "^1.0.1",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.0-next.6",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "rimraf": "^6.1.3",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.0",
    "svelte-eslint-parser": "^1.0.0",
    "svelte-sonner": "^0.3.25",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^0.2.1",
    "tailwindcss": "^3.4.16",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/svelte-virtual": "^3.13.24",
    "better-sqlite3": "^11.0.0",
    "nanoid": "^5",
    "snowflake-sdk": "^2.4.1",
    "svelte-codemirror-editor": "^2.1.0",
    "svelte-splitpanes": "0.8.0"
  }
}
